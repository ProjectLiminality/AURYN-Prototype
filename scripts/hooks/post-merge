#!/bin/bash
# Git hook: post-merge
# Automatically sync submodule context after merges (including git pull)
#
# This ensures .claude/submodule-context.md stays in sync with submodule state.

# Get the repo root (where this hook is installed)
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "Post-merge: Syncing submodule context..." >&2
"$REPO_ROOT/scripts/sync-submodule-context.sh" "$REPO_ROOT"
